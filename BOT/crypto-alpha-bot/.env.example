# ============================================================
# Crypto Alpha Bot - 環境変数設定
# このファイルを .env にコピーして値を入力してください
# cp .env.example .env
# ============================================================

# ------ Telegram Bot ------
# @BotFatherで作成したBotのトークン
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# TelegramのあなたのChat ID（@userinfobot に /start で取得）
TELEGRAM_CHAT_ID=your_chat_id_here

# ------ X (Twitter) Cookie認証 ------
# 設定手順:
# 1. Chrome/EdgeでX.com にログイン
# 2. F12 → Application → Cookies → twitter.com
# 3. 以下3つの値をコピー
TWITTER_AUTH_TOKEN=your_auth_token_here
TWITTER_CT0=your_ct0_here
TWITTER_TWID=your_twid_here

# ------ AI判定 (Anthropic Claude) ------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# ------ 監視設定 ------
# 監視間隔（秒）- デフォルト: 1800秒（30分）
MONITOR_INTERVAL=1800

# スコア閾値（この値以上のツイートをTelegramに送信）- 1〜10
ALPHA_SCORE_THRESHOLD=7

# 送信する最大件数/回
MAX_TWEETS_PER_RUN=5
